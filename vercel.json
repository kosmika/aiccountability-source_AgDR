{
    "cleanUrls": true,
    "rewrites": [
          {
                  "source": "/manifesto",
                  "destination": "/Manifesto.html"
          },
          {
                  "source": "/",
                  "has": [
                            {
                                        "type": "host",
                                        "value": "groundzero.accountability.ai"
                            }
                  ],
                  "destination": "/groundzero/index.html"
          },
          {
                  "source": "/(.*)",
                  "has": [
                            {
                                        "type": "host",
                                        "value": "groundzero.accountability.ai"
                            }
                  ],
                  "destination": "/groundzero/$1"
          },
          {
                  "source": "/groundzero",
                  "destination": "/groundzero/index.html"
          },
          {
                  "source": "/groundzero/(.*)",
                  "destination": "/groundzero/$1"
          }
    ]
}
